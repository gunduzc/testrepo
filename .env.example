# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Two-Factor Authentication encryption key
TWO_FACTOR_SECRET_KEY="your-2fa-secret-key-change-in-production"

# OpenAI API (for LLM features - optional)
OPENAI_API_KEY=""

# Initial Admin (optional)
# Auto-creates admin account on first startup if both are set
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Instance Configuration (optional)
# INSTANCE_MODE: community | publisher | school (default: community)
# REGISTRATION: open | closed | domain | sso | invite | code
#   - open: Anyone can register (default for community/publisher)
#   - closed: Only admins can create accounts (default for school)
#   - domain: Only allowed email domains (set ALLOWED_DOMAINS)
# PREREQ_ENFORCEMENT: hard | soft | none (default: soft, or hard for school mode)
INSTANCE_MODE="community"
# REGISTRATION="open"
# ALLOWED_DOMAINS="school.edu,district.edu"
